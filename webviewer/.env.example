# WebViewer 环境变量配置示例
# 复制此文件为 .env 并填入真实值
# ⚠️ 不要将 .env 文件提交到 Git！

# ===========================================
# Feishu API 配置（可选）
# ===========================================
# 获取方式：https://open.feishu.cn/app
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here

# ===========================================
# 数据库配置（可选）
# ===========================================
# MOMHAND_DB_PATH=/root/.openclaw/workspace/webviewer/data/momhand.db

# ===========================================
# 服务器配置（可选）
# ===========================================
# WEBVIEWER_PORT=443
# WEBVIEWER_HOST=0.0.0.0
